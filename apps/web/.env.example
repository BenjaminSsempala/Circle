# Supabase — Settings > API in your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Cloudinary — cloudinary.com dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Google OAuth — console.cloud.google.com > Credentials
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...   # server-side only, never NEXT_PUBLIC_

# Resend — resend.com > API Keys
RESEND_API_KEY=re_...   # server-side only, never NEXT_PUBLIC_

# Site URL — no trailing slash
# Local:      http://localhost:3000
# Staging:    https://staging.thecircle.co
# Production: https://thecircle.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
