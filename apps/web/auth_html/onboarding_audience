<style>
        .option-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .option-card:hover {
            transform: translateY(-4px);
        }
        .option-card.selected {
            border-color: #005440;
            background-color: #f0f7f5;
            box-shadow: 0 10px 25px -5px rgba(15, 110, 86, 0.15);
        }
        .step-transition {
            animation: fadeInScale 0.6s ease-out forwards;
        }
        @keyframes fadeInScale {
            from { opacity: 0; transform: scale(0.98); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex flex-col">
<!-- Navigation Shell Suppressed: Transactional Onboarding Flow -->
<main class="flex-grow flex items-center justify-center px-margin-mobile md:px-margin-desktop py-xl">
<div class="max-w-[800px] w-full step-transition">
<!-- Progress Indicator -->
<div class="flex items-center gap-base mb-lg justify-center">
<div class="h-1 w-12 bg-primary-container rounded-full"></div>
<div class="h-1 w-12 bg-primary rounded-full"></div>
<div class="h-1 w-12 bg-outline-variant rounded-full"></div>
</div>
<!-- Header -->
<div class="text-center mb-xl">
<h1 class="font-headline-xl text-headline-xl md:text-headline-xl text-on-surface mb-md">
                    What brings you to ArtHearth today?
                </h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-[600px] mx-auto">
                    We’ll customize your experience to help you find the perfect East African artistry for your specific needs.
                </p>
</div>
<!-- Options Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-xl" id="options-container">
<!-- Option 1 -->
<button class="option-card group flex flex-col p-md bg-surface-container-lowest border border-outline-variant/30 rounded-xl text-left h-full" onclick="selectOption(this)">
<div class="mb-gutter bg-primary-fixed w-12 h-12 rounded-lg flex items-center justify-center group-hover:bg-primary-container transition-colors">
<span class="material-symbols-outlined text-primary group-hover:text-on-primary-container" data-icon="event">event</span>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">I'm booking for an event</h3>
<p class="font-caption text-caption text-on-surface-variant">Planning a corporate gala, festival, or community gathering.</p>
</button>
<!-- Option 2 -->
<button class="option-card group flex flex-col p-md bg-surface-container-lowest border border-outline-variant/30 rounded-xl text-left h-full" onclick="selectOption(this)">
<div class="mb-gutter bg-primary-fixed w-12 h-12 rounded-lg flex items-center justify-center group-hover:bg-primary-container transition-colors">
<span class="material-symbols-outlined text-primary group-hover:text-on-primary-container" data-icon="featured_seasonal_and_gifts">featured_seasonal_and_gifts</span>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">I'm looking for a personal gift</h3>
<p class="font-caption text-caption text-on-surface-variant">Commissioning unique pieces or private performances for loved ones.</p>
</button>
<!-- Option 3 -->
<button class="option-card group flex flex-col p-md bg-surface-container-lowest border border-outline-variant/30 rounded-xl text-left h-full" onclick="selectOption(this)">
<div class="mb-gutter bg-primary-fixed w-12 h-12 rounded-lg flex items-center justify-center group-hover:bg-primary-container transition-colors">
<span class="material-symbols-outlined text-primary group-hover:text-on-primary-container" data-icon="explore">explore</span>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">I'm just browsing</h3>
<p class="font-caption text-caption text-on-surface-variant">Discovering talent and exploring the creative rhythm of the hearth.</p>
</button>
</div>
<!-- Primary Action -->
<div class="flex flex-col items-center gap-md">
<button class="bg-primary text-on-primary px-xl py-md rounded-lg font-body-md font-bold shadow-lg hover:bg-primary-container transition-all active:scale-95 opacity-50 cursor-not-allowed" disabled="" id="complete-btn">
                    Complete Setup
                </button>
<button class="text-on-surface-variant font-label-mono hover:text-primary transition-colors uppercase tracking-widest text-[12px]">
                    Skip for now
                </button>
</div>
</div>
</main>
<!-- Footer -->
<footer class="w-full py-md border-t border-outline-variant/20">
<div class="px-margin-desktop flex flex-col md:flex-row justify-between items-center opacity-60">
<span class="font-label-mono text-caption">© 2024 ArtHearth. Celebrating African Excellence.</span>
<div class="flex gap-md mt-sm md:mt-0">
<a class="font-label-mono text-caption hover:text-primary transition-colors" href="#">Privacy Policy</a>
<a class="font-label-mono text-caption hover:text-primary transition-colors" href="#">Terms of Service</a>
</div>
</div>
</footer>
<script>
        function selectOption(element) {
            // Remove selection from others
            const cards = document.querySelectorAll('.option-card');
            cards.forEach(card => card.classList.remove('selected'));
            
            // Add selection to clicked
            element.classList.add('selected');
            
            // Enable button
            const btn = document.getElementById('complete-btn');
            btn.classList.remove('opacity-50', 'cursor-not-allowed');
            btn.classList.add('opacity-100');
            btn.disabled = false;
            
            // Trigger micro-interaction
            element.style.transform = 'scale(0.98)';
            setTimeout(() => {
                element.style.transform = '';
            }, 100);
        }

        // Floating particle effect for "Hearth" energy
        function createParticles() {
            const body = document.body;
            for(let i = 0; i < 5; i++) {
                const particle = document.createElement('div');
                particle.className = 'fixed rounded-full bg-primary-fixed-dim/20 pointer-events-none';
                const size = Math.random() * 200 + 50;
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                particle.style.left = `${Math.random() * 100}vw`;
                particle.style.top = `${Math.random() * 100}vh`;
                particle.style.filter = 'blur(80px)';
                particle.style.zIndex = '-1';
                body.appendChild(particle);
                
                animateParticle(particle);
            }
        }

        function animateParticle(p) {
            const x = (Math.random() - 0.5) * 40;
            const y = (Math.random() - 0.5) * 40;
            p.animate([
                { transform: `translate(0, 0)` },
                { transform: `translate(${x}px, ${y}px)` },
                { transform: `translate(0, 0)` }
            ], {
                duration: 10000 + Math.random() * 5000,
                iterations: Infinity,
                easing: 'ease-in-out'
            });
        }

        createParticles();
    </script>
</body></html>